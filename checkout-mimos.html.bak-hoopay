<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sofis Hub | Checkout Mimos</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />

  <script>
    (() => {
      const t = localStorage.getItem("theme");
      if (t === "dark") document.documentElement.classList.add("dark-mode");
    })();
  </script>

  <style>
    html { background: #ffffff; }
    html.dark-mode { background: #08090c; }
    body { opacity: 0; visibility: hidden; }
    html.page-ready body { opacity: 1; visibility: visible; transition: opacity 0.15s ease; }
  </style>

  <link rel="stylesheet" href="style.css" />

  <style>
    /* ══════════════════════════════════════════
       CHECKOUT MIMOS
    ══════════════════════════════════════════ */

    .gift-hero {
      position: relative;
      padding: 56px 0 42px;
      overflow: hidden;
      text-align: center;
    }

    .gift-hero-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .gift-orb {
      position: absolute;
      width: 430px; height: 430px;
      top: -210px; left: 50%;
      transform: translateX(-50%);
      border-radius: 50%;
      filter: blur(86px);
      background: radial-gradient(circle, rgba(236,205,45,0.17), transparent 68%);
    }

    .gift-grid-bg {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 52px 52px;
      mask-image: radial-gradient(ellipse 68% 68% at 50% 50%, black, transparent);
      opacity: 0.32;
    }

    .gift-hero-inner {
      position: relative;
      z-index: 1;
    }

    .gift-hero-icon {
      width: 64px; height: 64px;
      margin: 0 auto 18px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, #fff3a3, #eccd2d);
      color: #1b1704;
      font-size: 1.6rem;
      box-shadow: 0 0 42px rgba(236,205,45,0.32);
    }

    .gift-hero h1 {
      color: var(--text);
      font-size: clamp(2rem, 4.6vw, 3.5rem);
      line-height: 1.02;
      letter-spacing: -0.06em;
      margin-bottom: 10px;
    }

    .gift-hero p {
      max-width: 520px;
      margin: 0 auto;
      color: var(--muted);
      line-height: 1.65;
    }

    .gift-main {
      padding: 34px 0 82px;
    }

    .gift-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 420px;
      gap: 28px;
      align-items: start;
    }

    .gift-card {
      border-radius: 34px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    html:not(.dark-mode) .gift-card {
      background: linear-gradient(180deg, #fff 0%, #fffdf5 100%);
      border-color: rgba(20,20,20,0.12);
      box-shadow: 0 26px 65px rgba(0,0,0,0.10), 0 6px 18px rgba(0,0,0,0.05);
    }

    .gift-product-card {
      padding: 14px;
    }

    .gift-product-media {
      position: relative;
      min-height: 560px;
      border-radius: 26px;
      overflow: hidden;
      background: var(--yellow-soft);
    }

    .gift-product-media img {
      width: 100%; height: 100%;
      min-height: 560px;
      display: block;
      object-fit: cover;
      object-position: top center;
      filter: saturate(0.94) contrast(1.03);
    }

    .gift-product-media::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, transparent 45%, rgba(0,0,0,0.60) 100%),
        radial-gradient(circle at top right, rgba(236,205,45,0.23), transparent 45%);
      pointer-events: none;
    }

    .gift-product-floating {
      position: absolute;
      left: 22px; right: 22px; bottom: 22px;
      z-index: 2;
      padding: 20px;
      border-radius: 24px;
      background: rgba(12,13,16,0.58);
      border: 1px solid rgba(236,205,45,0.28);
      backdrop-filter: blur(18px);
      color: #fff;
    }

    .gift-product-floating .gift-badge {
      display: inline-flex;
      padding: 7px 12px;
      border-radius: 999px;
      background: rgba(236,205,45,0.16);
      color: #fff3a3;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .gift-product-floating h2 {
      font-size: clamp(1.7rem, 4vw, 2.8rem);
      line-height: 1.02;
      letter-spacing: -0.06em;
      margin-bottom: 8px;
    }

    .gift-product-floating p {
      color: rgba(255,255,255,0.78);
      line-height: 1.55;
      max-width: 560px;
    }

    .gift-info {
      padding: 28px;
    }

    .gift-info-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 22px;
    }

    .gift-info-head h2 {
      color: var(--text);
      font-size: 1.45rem;
      line-height: 1.15;
      letter-spacing: -0.05em;
      margin-bottom: 7px;
    }

    .gift-info-head p {
      color: var(--muted);
      font-size: 0.94rem;
      line-height: 1.55;
    }

    .gift-price-box {
      text-align: right;
      flex-shrink: 0;
    }

    .gift-price-box small {
      display: block;
      color: var(--muted);
      font-size: 0.74rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 3px;
    }

    .gift-price-box strong {
      display: block;
      color: var(--yellow-dark);
      font-size: 1.9rem;
      line-height: 1;
      letter-spacing: -0.06em;
    }

    .gift-message {
      padding: 20px;
      border-radius: 24px;
      border: 1px solid rgba(236,205,45,0.26);
      background: radial-gradient(circle at top left, rgba(236,205,45,0.13), transparent 60%), var(--bg-card);
      margin-bottom: 20px;
    }

    html:not(.dark-mode) .gift-message {
      background: radial-gradient(circle at top left, rgba(236,205,45,0.16), transparent 60%), #fffaf0;
    }

    .gift-message span {
      display: block;
      color: var(--yellow-dark);
      font-weight: 900;
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 7px;
    }

    .gift-message p {
      color: var(--text);
      line-height: 1.65;
      font-weight: 650;
    }

    .gift-instructions {
      display: grid;
      gap: 10px;
      margin-bottom: 24px;
    }

    .gift-inst-item {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      padding: 15px;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: color-mix(in srgb, var(--bg-card) 86%, transparent);
    }

    html:not(.dark-mode) .gift-inst-item { background: rgba(255,255,255,0.82); }

    .gift-inst-icon {
      width: 28px; height: 28px;
      flex-shrink: 0;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, #fff3a3, #eccd2d);
      color: #1b1704;
      font-size: 0.76rem;
      font-weight: 900;
    }

    .gift-inst-item strong {
      display: block;
      color: var(--text);
      font-size: 0.92rem;
      margin-bottom: 2px;
    }

    .gift-inst-item span {
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.45;
    }

    .gift-pay-summary {
      padding: 28px;
    }

    .gift-pay-summary h2 {
      color: var(--text);
      font-size: 1.1rem;
      letter-spacing: -0.03em;
      margin-bottom: 18px;
    }

    .gift-line {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 650;
    }

    .gift-line strong {
      color: var(--text);
      text-align: right;
    }

    .gift-line.total {
      border-bottom: 0;
      padding-top: 18px;
      margin-bottom: 20px;
      color: var(--text);
      font-weight: 900;
    }

    .gift-line.total strong {
      color: var(--yellow-dark);
      font-size: 1.55rem;
      letter-spacing: -0.05em;
    }

    .gift-pay-btn {
      width: 100%;
      min-height: 56px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: linear-gradient(135deg, #fff3a3 0%, #eccd2d 55%, #d8ad19 100%);
      color: #171300;
      font-weight: 900;
      border: 0;
      box-shadow: 0 16px 36px rgba(236,205,45,0.24), 0 4px 12px rgba(0,0,0,0.12);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .gift-pay-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 22px 48px rgba(236,205,45,0.32), 0 6px 16px rgba(0,0,0,0.14);
    }

    .gift-secure {
      margin-top: 16px;
      text-align: center;
      color: var(--muted);
      font-size: 0.84rem;
      font-weight: 650;
    }

    .gift-thank-you {
      margin-top: 18px;
      padding: 18px;
      border-radius: 22px;
      background: var(--yellow-soft);
      color: var(--yellow-dark);
      font-size: 0.9rem;
      line-height: 1.55;
      font-weight: 750;
    }

    .gift-back {
      display: inline-flex;
      margin-top: 18px;
      color: var(--muted);
      font-weight: 700;
      font-size: 0.9rem;
    }

    .gift-back:hover { color: var(--yellow-dark); }

    @media (max-width: 1020px) {
      .gift-layout {
        grid-template-columns: 1fr;
      }

      .gift-product-media,
      .gift-product-media img {
        min-height: 480px;
      }
    }

    @media (max-width: 640px) {
      .gift-main {
        padding-top: 22px;
      }

      .gift-product-card,
      .gift-info,
      .gift-pay-summary {
        padding: 18px;
      }

      .gift-product-media,
      .gift-product-media img {
        min-height: 420px;
      }

      .gift-product-floating {
        left: 14px; right: 14px; bottom: 14px;
        padding: 16px;
      }

      .gift-info-head {
        flex-direction: column;
      }

      .gift-price-box {
        text-align: left;
      }
    }
  </style>
</head>

<body>
  <a href="#conteudo-principal" class="skip-link">Pular para o conteúdo</a>

  <header class="header">
    <div class="container nav">
      <div class="logo">
        <a href="index.html">Sofis<span>Hub</span></a>
      </div>

      <nav class="nav-desktop" aria-label="Navegação principal">
        <ul class="menu">
          <li><a href="index.html">Início</a></li>
          <li><a href="SobreMim.html">Sobre mim</a></li>
          <li><a href="amostras.html">Amostras</a></li>
          <li><a href="packs.html">Packs</a></li>
          <li><a href="vip.html">VIP</a></li>
          <li><a href="servicos.html">Serviços</a></li>
          <li><a href="webnamoro.html">Webnamoro</a></li>
          <li><a href="mimos.html" class="ativo">Mimos</a></li>
        </ul>
      </nav>

      <div class="nav-actions">
        <a href="vip.html" class="btn btn-nav">Acesso VIP</a>

        <button class="theme-switch" id="themeToggle" aria-label="Alternar tema">
          <span class="switch-bg"></span>
          <span class="switch-moon-shade"></span>
          <span class="switch-cloud cloud-1"></span>
          <span class="switch-cloud cloud-2"></span>
          <span class="switch-cloud cloud-3"></span>
          <span class="switch-stars"></span>
          <span class="switch-thumb"></span>
        </button>

        <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobileMenuPanel">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <nav class="mobile-menu-panel" id="mobileMenuPanel" aria-label="Menu mobile" aria-hidden="true">
      <a href="index.html">Início</a>
      <a href="SobreMim.html">Sobre mim</a>
      <a href="amostras.html">Amostras</a>
      <a href="packs.html">Packs</a>
      <a href="vip.html">VIP</a>
      <a href="servicos.html">Serviços</a>
      <a href="webnamoro.html">Webnamoro</a>
      <a href="mimos.html">Mimos</a>
      <a href="vip.html" class="mobile-cta">Acesso VIP</a>
    </nav>
  </header>

  <main id="conteudo-principal">
    <section class="gift-hero" aria-labelledby="gift-hero-titulo">
      <div class="gift-hero-bg" aria-hidden="true">
        <div class="gift-orb"></div>
        <div class="gift-grid-bg"></div>
      </div>
      <div class="container gift-hero-inner">
        <div class="gift-hero-icon" aria-hidden="true">♡</div>
        <h1 id="gift-hero-titulo">Finalizar mimo</h1>
        <p>Confira o presente escolhido, veja as instruções e conclua com uma mensagem carinhosa.</p>
      </div>
    </section>

    <section class="gift-main" aria-label="Checkout de mimos">
      <div class="container gift-layout">
        <div>
          <article class="gift-card gift-product-card" aria-label="Mimo escolhido">
            <div class="gift-product-media">
              <img id="gift-img" src="sofisa.jpg" alt="" width="720" height="900" />
              <div class="gift-product-floating">
                <span class="gift-badge" id="gift-badge">Mimo premium</span>
                <h2 id="gift-floating-name">Corset Underbust</h2>
                <p id="gift-floating-desc">Um presente elegante e marcante.</p>
              </div>
            </div>
          </article>

          <a href="mimos.html#vitrine" class="gift-back">← Escolher outro mimo</a>
        </div>

        <aside class="gift-card" aria-label="Resumo e pagamento">
          <div class="gift-info">
            <div class="gift-info-head">
              <div>
                <h2 id="gift-name">Corset Underbust</h2>
                <p id="gift-desc">Peça marcante, elegante e perfeita para um visual premium.</p>
              </div>
              <div class="gift-price-box">
                <small>Valor do mimo</small>
                <strong id="gift-price">R$ 189,90</strong>
              </div>
            </div>

            <div class="gift-message">
              <span>Mensagem de agradecimento</span>
              <p id="gift-message">Obrigada por escolher um mimo tão especial. Vou lembrar desse carinho com um sorriso enorme.</p>
            </div>

            <div class="gift-instructions" id="gift-instructions" aria-label="Instruções para presentear">
              <!-- preenchido via JS -->
            </div>
          </div>

          <div class="gift-pay-summary">
            <h2>Resumo do presente</h2>
            <div class="gift-line"><span>Mimo escolhido</span><strong id="gift-summary-name">Corset Underbust</strong></div>
            <div class="gift-line"><span>Entrega do carinho</span><strong>Mensagem direta</strong></div>
            <div class="gift-line total"><span>Total</span><strong id="gift-total">R$ 189,90</strong></div>

            <a href="#" class="gift-pay-btn" id="gift-pay-btn" target="_blank" rel="noopener">
              <span>Finalizar pagamento</span>
              <span aria-hidden="true">→</span>
            </a>

            <p class="gift-secure">Pagamento seguro, discreto e exclusivo para mimos.</p>
            <div class="gift-thank-you" id="gift-thanks">
              Seu presente chega como um gesto de carinho — e você recebe meu agradecimento personalizado.
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-content">
      <p class="footer-logo">Sofis<span>Hub</span></p>
      <p>Plataforma exclusiva</p>
    </div>
  </footer>

  <script src="script.js"></script>
  <script>
    const MIMOS_CATALOG = {
      "corset-underbust": {
        name: "Corset Underbust",
        price: 189.9,
        image: "sofisa.jpg",
        badge: "Mais desejado",
        desc: "Peça marcante, elegante e perfeita para um visual premium.",
        info: "Um presente sofisticado, com presença e personalidade. Ideal para quem quer escolher algo memorável.",
        message: "Obrigada por escolher um mimo tão especial. Esse corset tem aquele toque elegante que eu amo — vou lembrar do seu carinho sempre que usar.",
