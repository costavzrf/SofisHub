      "ensaio-fotos": { name: "Ensaio de Fotos", price: 399.9, image: "sofisa.jpg", badge: "Glow", desc: "Um presente para registrar beleza e autoestima.", info: "Um mimo premium escolhido para demonstrar carinho de um jeito elegante.", message: "Obrigada por escolher Ensaio de Fotos. Esse mimo transforma carinho em presença.", thanks: "Obrigada pelo presente. Seu gesto foi recebido com muito carinho.", instructions: ["Confira se o mimo escolhido está correto.", "Clique em Finalizar pagamento para combinar o envio pelo atendimento.", "Depois da confirmação, eu recebo o presente e te mando um agradecimento personalizado."], whatsapp: "Quero%20presentear%20com%20Ensaio%20de%20Fotos" },
      "mimo-surpresa": { name: "Mimo Surpresa", price: 150.0, image: "sofisa.jpg", badge: "Surpresa", desc: "Você escolhe o valor e deixa a surpresa acontecer.", info: "Um mimo premium escolhido para demonstrar carinho de um jeito elegante.", message: "Obrigada por escolher Mimo Surpresa. Esse mimo transforma carinho em presença.", thanks: "Obrigada pelo presente. Seu gesto foi recebido com muito carinho.", instructions: ["Confira se o mimo escolhido está correto.", "Clique em Finalizar pagamento para combinar o envio pelo atendimento.", "Depois da confirmação, eu recebo o presente e te mando um agradecimento personalizado."], whatsapp: "Quero%20presentear%20com%20Mimo%20Surpresa" }
    };

    const formatPrice = (value) => value.toLocaleString("pt-BR", {
      style: "currency",
      currency: "BRL"
    });

    const params = new URLSearchParams(window.location.search);
    const productKey = params.get("produto") || "corset-underbust";
    const product = MIMOS_CATALOG[productKey] || MIMOS_CATALOG["corset-underbust"];

    const giftImg = document.getElementById("gift-img");
    const price = formatPrice(product.price);

    giftImg.src = product.image;
    giftImg.alt = product.name;

    document.getElementById("gift-badge").textContent = product.badge;
    document.getElementById("gift-floating-name").textContent = product.name;
    document.getElementById("gift-floating-desc").textContent = product.info;
    document.getElementById("gift-name").textContent = product.name;
    document.getElementById("gift-desc").textContent = product.desc;
    document.getElementById("gift-price").textContent = price;
    document.getElementById("gift-message").textContent = product.message;
    document.getElementById("gift-summary-name").textContent = product.name;
    document.getElementById("gift-total").textContent = price;
    document.getElementById("gift-thanks").textContent = product.thanks;

    const instructions = document.getElementById("gift-instructions");
    instructions.innerHTML = product.instructions.map((item, index) => `
      <div class="gift-inst-item">
        <span class="gift-inst-icon">${index + 1}</span>
        <div>
          <strong>${index === 0 ? "Confira o mimo" : index === 1 ? "Finalize com segurança" : "Receba o agradecimento"}</strong>
          <span>${item}</span>
        </div>
      </div>
    `).join("");

    const payText = `${product.whatsapp}%20-%20Valor%3A%20${encodeURIComponent(price)}`;
    document.getElementById("gift-pay-btn").href = `https://wa.me/seunumero?text=${payText}`;
  </script>
</body>
</html>
