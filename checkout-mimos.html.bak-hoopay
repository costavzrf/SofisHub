        ],
        whatsapp: "Quero%20presentear%20com%20o%20Perfume%20Assinatura"
      },
      "spa-day": {
        name: "Spa Day",
        price: 299.9,
        image: "sofisa.jpg",
        badge: "Cuidado especial",
        desc: "Um dia de cuidado, descanso e energia boa.",
        info: "Um presente de descanso e autocuidado, perfeito para recarregar com carinho.",
        message: "Que presente mais cuidadoso. Um Spa Day é carinho em forma de pausa, descanso e energia boa.",
        thanks: "Obrigada por cuidar de mim com esse mimo. Esse gesto é muito especial.",
        instructions: [
